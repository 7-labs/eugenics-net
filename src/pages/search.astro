---
import BaseLayout from "@layouts/BaseLayout.astro";
import { foundationalArticles } from "@data/site";

const title = "Search";
const description = "Search the Eugenics: A Critical History archive across articles, glossary entries, teaching resources, and policy pages.";
---

<BaseLayout
  title={title}
  description={description}
  path="/search.html"
  activePath="/search.html"
  robots="noindex"
  pagefindIndex={false}
>
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script slot="head" src="/pagefind/pagefind-ui.js" defer></script>
  <script slot="head" src="/search.js" defer></script>
  <main class="page search-page" data-pagefind-ignore="all">
    <header class="page-header">
      <p class="eyebrow">Archive lookup</p>
      <h1>Search the Archive</h1>
      <p class="lead">
        Search across foundational articles, glossary terms, teaching materials, and editorial policy pages.
      </p>
    </header>

    <section class="search-panel" aria-label="Site search">
      <label class="search-label" for="site-search-input">Search terms</label>
      <div id="search" class="search-widget"></div>
      <noscript>
        <div class="notice-panel search-noscript">
          <h2>Search Requires JavaScript</h2>
          <p>
            The site remains fully static, but the search index needs JavaScript in the browser. Use the main archive links below if scripting is unavailable.
          </p>
          <ul class="fallback-list">
            <li><a href="/archive">Archive index</a></li>
            <li><a href="/glossary">Glossary</a></li>
            <li><a href="/history">History hub</a></li>
            <li><a href="/bioethics">Bioethics hub</a></li>
            <li><a href="/teaching">Teaching resources</a></li>
            {foundationalArticles.map((article) => (
              <li><a href={`/${article.slug}`}>{article.title}</a></li>
            ))}
          </ul>
        </div>
      </noscript>
    </section>
  </main>
</BaseLayout>
