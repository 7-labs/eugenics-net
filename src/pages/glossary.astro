---
import BaseLayout from "@layouts/BaseLayout.astro";
import SourcePacketPanel from "@components/SourcePacketPanel.astro";
import { getEntry } from "astro:content";
import { glossaryTerms } from "@data/glossary";
import { definedTermSetJsonLd } from "@utils/seo";

const title = "Glossary";
const description = "Definitions for core terms used in critical eugenics history, scientific racism, genetics, and bioethics education.";
const path = "/glossary.html";
const jsonLd = definedTermSetJsonLd({ title, description, path, terms: glossaryTerms });
const sourcePacket = (await getEntry("sourcePackets", "glossary"))?.data;
const sortedTerms = [...glossaryTerms].sort((a, b) => a.term.localeCompare(b.term));
const letterGroups = [];
for (const entry of sortedTerms) {
  const letter = entry.term[0].toUpperCase();
  const group = letterGroups.find((g) => g.letter === letter);
  if (group) group.terms.push(entry);
  else letterGroups.push({ letter, terms: [entry] });
}
---

<BaseLayout title={title} description={description} path={path} jsonLd={jsonLd}>
  <main class="page">
    <header class="page-header">
      <p class="eyebrow">Defined terms</p>
      <h1>{title}</h1>
      <p class="lead">These definitions are written for education and critique, not for biological ranking or policy prescription.</p>
    </header>

    <section class="glossary-list" aria-labelledby="terms-heading">
      <h2 id="terms-heading">Terms</h2>
      <nav class="az-index" aria-label="Jump to a letter">
        {letterGroups.map((group) => (
          <a href={`#gloss-${group.letter}`}>{group.letter}</a>
        ))}
      </nav>
      {letterGroups.map((group) => (
        <div class="gloss-group">
          <h3 class="gloss-letter" id={`gloss-${group.letter}`}>{group.letter}</h3>
          {group.terms.map((term) => (
            <article id={term.slug}>
              <h4>{term.term}</h4>
              <p>{term.definition}</p>
            </article>
          ))}
        </div>
      ))}
    </section>

    {sourcePacket && <SourcePacketPanel packet={sourcePacket} mode="hub" />}
  </main>
</BaseLayout>
