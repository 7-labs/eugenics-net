---
import BaseLayout from "@layouts/BaseLayout.astro";
import SourceList from "@components/SourceList.astro";
import SourcePacketPanel from "@components/SourcePacketPanel.astro";
import { getEntry } from "astro:content";
import { commonSources } from "@data/site";
import { learningResourceJsonLd } from "@utils/seo";

const title = "Teaching Resources";
const description = "Teaching guidance for educators covering eugenics history, scientific racism, primary sources, and modern bioethics responsibly.";
const path = "/teaching.html";
const sources = [commonSources.ucl, commonSources.archive, commonSources.nhgri, commonSources.uclInquiry];
const jsonLd = learningResourceJsonLd({ title, description, path });
const sourcePacket = (await getEntry("sourcePackets", "teaching"))?.data;
const coursePaths = [
  {
    title: "90-Minute Intro",
    duration: "One class meeting",
    steps: [
      "Open with the anti-endorsement statement and content warning.",
      "Define eugenics, scientific racism, forced sterilization, and genetic discrimination.",
      "Use the timeline and one secondary-source excerpt before any primary material.",
      "Close with a rights-based discussion: consent, dignity, disability rights, and state power."
    ]
  },
  {
    title: "Two-Week Seminar",
    duration: "Four to six class meetings",
    steps: [
      "Begin with definition, scientific racism, and why heredity cannot be used to rank human worth.",
      "Move through forced sterilization law, the Eugenics Record Office, country cases, and survivor-centered archive questions.",
      "Compare UNESCO, WHO, and Nuffield governance language on consent, justice, dignity, and disability impact.",
      "End with a source packet exercise in which students identify claim, evidence, caveat, affected community, and teaching risk."
    ]
  },
  {
    title: "Archive Source Analysis",
    duration: "Workshop",
    steps: [
      "Use the archive template before showing any historical primary-source excerpt.",
      "Identify creator, institution, audience, harmful claim, affected groups, and missing context.",
      "Discuss why an archive item should not be republished without warnings and critique.",
      "Require a reflection on power: who classified whom, and with what consequences?"
    ]
  },
  {
    title: "Modern Genetics Ethics",
    duration: "Upper-level unit",
    steps: [
      "Start with voluntary clinical genetics and genetic discrimination safeguards.",
      "Move to embryo selection, genome editing, disability-rights critiques, and access inequality.",
      "Use source-backed policy statements rather than speculative technology hype.",
      "End with governance questions about consent, accountability, and affected communities."
    ]
  }
];
const sourceUseRules = [
  "Do not show propaganda images, case files, or dehumanizing primary language at the start of a lesson.",
  "Give students a source packet first: creator, institution, audience, harmful claim, affected community, source role, and caveat.",
  "Use secondary and institutional sources to establish context before any excerpt from a harmful historical source.",
  "Avoid mock classification exercises, ranking exercises, heredity games, or debates over whether targeted groups deserved rights.",
  "When survivor or affected-community material is used, summarize respectfully and avoid extracting trauma as a dramatic classroom device.",
  "Close lessons with safeguards: consent, bodily autonomy, privacy, disability rights, human dignity, and anti-discrimination."
];
const printablePrompts = [
  "What institution made the claim credible, and what power did that institution have over affected people?",
  "Which word or category in the source looks technical but carries a moral or political judgment?",
  "What does the source say, what does it omit, and who could not answer back inside the record?",
  "How would the meaning change if the page centered a survivor, family, disability-rights, or civil-rights perspective first?",
  "What modern safeguard would directly answer the harm visible in the source?"
];
const worksheetSteps = [
  "Name the source creator, institution, date, audience, and publication purpose.",
  "Identify the harmful claim without repeating it as neutral vocabulary.",
  "List the affected communities and the people least able to refuse the institution's decision.",
  "Separate what the source can prove from what it cannot prove.",
  "Write one rights-based safeguard that responds to the harm: consent, bodily autonomy, privacy, disability rights, anti-discrimination, or accountability."
];
---

<BaseLayout title={title} description={description} path={path} jsonLd={jsonLd} alert="Teaching this history requires critical education, context, care, and explicit rejection of dehumanizing claims.">
  <main class="page">
    <header class="page-header">
      <p class="eyebrow">Educator route</p>
      <h1>{title}</h1>
      <p class="lead">A responsible critical education lesson helps students understand harm, power, pseudoscience, and resistance without giving eugenic claims a neutral platform.</p>
    </header>

    <section class="link-grid" aria-labelledby="teaching-routes">
      <h2 id="teaching-routes">Teaching Modules</h2>
      <article>
        <h3><a href="/teaching-eugenics-responsibly">Teaching Eugenics Responsibly</a></h3>
        <p>A foundation guide for lesson framing, source use, classroom discussion, and boundaries.</p>
      </article>
      <article>
        <h3><a href="/eugenics-timeline-1883-present">Timeline Handout</a></h3>
        <p>A chronology that can anchor a short unit without centering propaganda materials.</p>
      </article>
      <article>
        <h3><a href="/archive">Archive Source Template</a></h3>
        <p>A model for teaching primary-source analysis with content warnings and editorial notes.</p>
      </article>
    </section>

    <section>
      <h2>Course Paths</h2>
      <div class="course-paths">
        {coursePaths.map((pathway) => (
          <article>
            <p class="eyebrow">{pathway.duration}</p>
            <h3>{pathway.title}</h3>
            <ol>
              {pathway.steps.map((step) => <li>{step}</li>)}
            </ol>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2>Guidelines for Educators</h2>
      <ul>
        <li>Begin with a clear anti-endorsement statement and a content warning.</li>
        <li>Define eugenics, scientific racism, forced sterilization, and genetic discrimination before showing primary materials.</li>
        <li>Use archival sources only with context notes that name harmful claims and affected communities.</li>
        <li>Center survivor, disability-rights, civil-rights, and human-rights perspectives.</li>
        <li>Avoid simulations that rank people, assign reproductive value, or casually repeat dehumanizing language.</li>
      </ul>
    </section>

    <section class="notice-panel" aria-labelledby="source-rules-heading">
      <h2 id="source-rules-heading">Printable Source-Use Rules</h2>
      <p>These rules are designed for handouts, lesson plans, and archive workshops. They keep the class focused on critique and evidence rather than spectacle or reenactment.</p>
      <ol>
        {sourceUseRules.map((rule) => <li>{rule}</li>)}
      </ol>
    </section>

    <section aria-labelledby="discussion-prompts-heading">
      <h2 id="discussion-prompts-heading">Discussion Prompts</h2>
      <p>Use these prompts after students have read the content warning, project position, and source packet. They are intended to analyze power and evidence, not to debate the humanity or rights of targeted communities.</p>
      <ul>
        {printablePrompts.map((prompt) => <li>{prompt}</li>)}
      </ul>
    </section>

    <section class="notice-panel" aria-labelledby="worksheet-heading">
      <h2 id="worksheet-heading">Classroom Source-Analysis Worksheet</h2>
      <p>This worksheet can be copied into a lesson plan without adding downloads or exposing raw primary-source scans. It keeps students focused on source creation, institutional power, affected communities, and rights safeguards.</p>
      <ol>
        {worksheetSteps.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    <section>
      <h2>Downloadable Pack Roadmap</h2>
      <p>A later release can package slides, prompts, a timeline handout, and worksheet PDFs after external review. The current page provides the worksheet text directly so educators can use it without waiting for a download bundle.</p>
    </section>

    {sourcePacket && <SourcePacketPanel packet={sourcePacket} mode="hub" />}

    <SourceList sources={sources} />
  </main>
</BaseLayout>
