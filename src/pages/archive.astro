---
import ArchiveEntryTemplate from "@components/ArchiveEntryTemplate.astro";
import SourceList from "@components/SourceList.astro";
import SourcePacketPanel from "@components/SourcePacketPanel.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { annotatedSampleEntries, archiveCategories } from "@data/archive";
import { commonSources } from "@data/site";
import { webPageJsonLd } from "@utils/seo";

const title = "Critical Archive Model";
const description = "Archive policy for contextualizing primary sources about eugenics, scientific racism, forced sterilization, and related harms.";
const path = "/archive.html";
const sources = [commonSources.archive, commonSources.ushmm, commonSources.uclCollections, commonSources.cshlEro];
const sourcePacket = (await getEntry("sourcePackets", "archive"))?.data;
const plannedCollections = [
  "Sterilization laws and court records with survivor-centered context notes.",
  "Institutional organizations, including research offices and public-health boards.",
  "Country case files for the United States, Britain, Canada, Sweden, and Nazi Germany.",
  "People and institutions entries that avoid hero narratives and name affected communities.",
  "Image and propaganda context entries published only when visual evidence is necessary."
];
---

<BaseLayout title={title} description={description} path={path} jsonLd={webPageJsonLd({ title, description, path })} alert="Primary materials must never appear here without context, warnings, and critique.">
  <main class="page">
    <header class="page-header">
      <p class="eyebrow">Archive design</p>
      <h1>{title}</h1>
      <p class="lead">The archive exists to preserve evidence of harm, not to reproduce propaganda without interpretation.</p>
    </header>

    <section id="archive-policy">
      <h2>Archive Policy</h2>
      <p>Every archival item must include a content warning, provenance note, historical context, affected communities, harmful claims contained in the item, and an editorial explanation of why the item matters today. Items that cannot be contextualized responsibly should remain offline until reviewed.</p>
    </section>

    <section class="notice-panel" aria-labelledby="readiness-heading">
      <h2 id="readiness-heading">Archive Item Readiness Checklist</h2>
      <p>An item is publication-ready only when every box below is satisfied. If any item is unmet, the material stays offline.</p>
      <ul class="readiness-checklist">
        <li>Content warning written for the specific harm in the item.</li>
        <li>Provenance and source citation verified.</li>
        <li>Historical context note that explains the period and institution.</li>
        <li>Harmful claims named in critique, never repeated as neutral fact.</li>
        <li>Affected communities identified, including who could not refuse.</li>
        <li>Editorial "why this matters today" note written.</li>
        <li>Source-rights and republication check passed.</li>
        <li>Named review owner has signed off.</li>
        <li>No raw download, propaganda image, or extremist material exposed.</li>
      </ul>
    </section>

    <section>
      <h2>Initial Collections</h2>
      <div class="collection-grid">
        {archiveCategories.map((category) => (
          <article>
            <h3>{category.title}</h3>
            <p>{category.description}</p>
            <p class="future-path">{category.path}</p>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2>Annotated Entry Template</h2>
      <ArchiveEntryTemplate />
    </section>

    <section class="notice-panel">
      <h2>Publication Gate</h2>
      <p>No raw propaganda, old primary source, or image collection should be published as a standalone download in this release. Archive expansion requires review, context notes, content warnings, and source rights checks.</p>
    </section>

    <section class="notice-panel archive-gate">
      <h2>Planned Annotated Collections</h2>
      <p>The next archive release should add collection landing pages before any item-level publication. Each collection needs a scope note, source-rights check, content-warning policy, affected-community note, and review owner.</p>
      <ul>
        {plannedCollections.map((item) => <li>{item}</li>)}
      </ul>
      <p>No collection should expose downloadable primary-source scans, propaganda images, or historical extremist material until the item has passed the annotated-entry gate above.</p>
    </section>

    <section aria-labelledby="sample-entries-heading">
      <h2 id="sample-entries-heading">Annotated Non-Download Sample Entries</h2>
      <p>These are publication models, not raw primary-source downloads. They show the fields a sensitive item must pass before any future archive expansion.</p>
      <div class="annotated-samples">
        {annotatedSampleEntries.map((entry) => (
          <article>
            <h3>{entry.title}</h3>
            <dl class="definition-list archive-template">
              <dt>Year / Country</dt>
              <dd>{entry.year}; {entry.country}</dd>
              <dt>Author / Institution</dt>
              <dd>{entry.authorInstitution}</dd>
              <dt>Historical Context</dt>
              <dd>{entry.historicalContext}</dd>
              <dt>Harmful Claims Contained</dt>
              <dd>{entry.harmfulClaims}</dd>
              <dt>Affected Groups</dt>
              <dd>{entry.affectedGroups}</dd>
              <dt>Why This Matters Today</dt>
              <dd>{entry.whyItMatters}</dd>
              <dt>Source Citation</dt>
              <dd>{entry.sourceCitation}</dd>
              <dt>Editorial Note</dt>
              <dd>{entry.editorialNote}</dd>
              <dt>Content Warning</dt>
              <dd>{entry.contentWarning}</dd>
            </dl>
          </article>
        ))}
      </div>
    </section>

    {sourcePacket && <SourcePacketPanel packet={sourcePacket} mode="hub" />}

    <SourceList sources={sources} title="Reference Models" />
  </main>
</BaseLayout>
