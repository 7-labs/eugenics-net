---
import BaseLayout from "@layouts/BaseLayout.astro";

const title = "Page Not Found";
const description = "The requested page could not be found in the Eugenics: A Critical History archive.";
const path = "/404.html";
---

<BaseLayout title={title} description={description} path={path} robots="noindex">
  <main class="page not-found-page">
    <header class="page-header">
      <p class="eyebrow">404</p>
      <h1>{title}</h1>
      <p class="lead">The requested page is not part of this archive. Start from one of the current research routes below.</p>
    </header>

    <section class="route-sections" aria-labelledby="not-found-routes">
      <h2 id="not-found-routes">Current Routes</h2>
      <div class="link-grid compact-grid">
        <article>
          <h3><a href="/index.html">Home</a></h3>
          <p>Start with the project position, research routes, and editorial standards.</p>
        </article>
        <article>
          <h3><a href="/history.html">History</a></h3>
          <p>Read the historical articles on eugenics, scientific racism, law, and institutions.</p>
        </article>
        <article>
          <h3><a href="/archive.html">Archive</a></h3>
          <p>Review the critical archive model and publication safeguards.</p>
        </article>
        <article>
          <h3><a href="/glossary.html">Glossary</a></h3>
          <p>Look up terms with plain-language definitions and critical framing.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
