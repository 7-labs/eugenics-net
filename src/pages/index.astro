---
import BaseLayout from "@layouts/BaseLayout.astro";
import SourceList from "@components/SourceList.astro";
import SourcePacketPanel from "@components/SourcePacketPanel.astro";
import { getEntry } from "astro:content";
import { commonSources, SITE } from "@data/site";
import { webPageJsonLd, webSiteJsonLd } from "@utils/seo";

const path = "/";
const sources = [
  commonSources.nhgri,
  commonSources.nhgriTimeline,
  commonSources.ushmm,
  commonSources.unescoGenome,
  commonSources.ucl,
  commonSources.archive
];
const routeGroups = [
  {
    title: "Core Explanations",
    items: [
      ["/what-is-eugenics", "What Is Eugenics?", "Definition, scope, harms, and responsible study."],
      ["/why-eugenics-is-scientifically-wrong", "Why Eugenics Is Scientifically Wrong", "Why complex traits cannot justify ranking people or coercive policy."],
      ["/is-eugenics-pseudoscience", "Is Eugenics Pseudoscience?", "How eugenics borrowed scientific language while failing scientific and ethical tests."],
      ["/eugenics-vs-genetics", "Eugenics vs. Genetics", "A practical boundary between heredity science and eugenic ideology."]
    ]
  },
  {
    title: "Laws & Institutions",
    items: [
      ["/forced-sterilization-laws", "Forced Sterilization Laws", "How law, medicine, and institutions denied reproductive autonomy."],
      ["/buck-v-bell-forced-sterilization", "Buck v. Bell", "A court case that shows how constitutional language was used to legitimize coercion."],
      ["/eugenics-record-office", "Eugenics Record Office", "An institutional route into data collection, pedigree studies, and policy advocacy."],
      ["/charles-davenport-and-institutional-eugenics", "Charles Davenport", "A profile of institutional eugenics without a hero narrative."]
    ]
  },
  {
    title: "People & Countries",
    items: [
      ["/francis-galton-and-the-origin-of-eugenics", "Francis Galton", "The origin of the term and the imperial context around heredity claims."],
      ["/eugenics-in-the-united-states", "United States", "State laws, public institutions, immigration restriction, and survivor legacy."],
      ["/eugenics-in-britain", "Britain", "Galton, UCL legacies, public debate, and institutional reckoning."],
      ["/eugenics-in-canada", "Canada", "Western Canadian sterilization laws and archive-centered accountability."],
      ["/eugenics-in-sweden", "Sweden", "A welfare-state case showing how coercion can be framed as social policy."]
    ]
  },
  {
    title: "Modern Bioethics",
    items: [
      ["/modern-eugenics-debate", "Modern Eugenics Debate", "How the term appears in debates about reproductive technology and social pressure."],
      ["/genetic-testing-embryo-selection-ethical-boundaries", "Genetic Testing and Embryo Selection", "Consent, disability rights, genetic discrimination, and access."],
      ["/crispr-enhancement-new-eugenics", "CRISPR and Enhancement", "Why governance must distinguish therapy, enhancement, pressure, and rights."],
      ["/eugenics-and-race", "Eugenics and Race", "Why race is a social and political category, not a biological ranking."]
    ]
  },
  {
    title: "Teaching",
    items: [
      ["/teaching", "Teaching Resources", "Course paths, classroom boundaries, and source-analysis guidance."],
      ["/teaching-eugenics-responsibly", "Teaching Eugenics Responsibly", "A foundation guide for warnings, framing, and classroom ethics."],
      ["/archive", "Critical Archive Model", "Archive publication gates and annotated-entry fields."]
    ]
  }
];
const sourcePacket = (await getEntry("sourcePackets", "index"))?.data;
---

<BaseLayout
  title={SITE.title}
  path={path}
  jsonLd={[webSiteJsonLd(), webPageJsonLd({ title: SITE.title, description: SITE.defaultDescription, path })]}
  preloadImage={true}
  preloadImageHref="/assets/archive-reading-room.webp"
>
  <main class="home-main">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Critical archive and educational resource</p>
        <h1>{SITE.title}</h1>
        <p class="lead">
          Documenting the history, harms, and modern legacy of eugenics, scientific racism, forced sterilization, and genetic discrimination.
        </p>
        <div class="hero-actions" aria-label="Primary routes">
          <a class="button" href="/what-is-eugenics">Read the definition</a>
          <a class="button secondary" href="/teaching">Use teaching resources</a>
          <a class="button secondary" href="/bioethics">Review bioethics boundaries</a>
          <a class="button secondary" href="/archive">Review the archive model</a>
        </div>
      </div>
    </section>

    <section class="notice-panel" aria-labelledby="position-title">
      <h2 id="position-title">Project Position</h2>
      <p>
        This site does not endorse eugenics. It documents and critiques its history, harms, and modern legacy. Historical materials are presented only for education, documentation, and critical study.
      </p>
    </section>

    <section class="route-sections" aria-labelledby="routes-title">
      <h2 id="routes-title">Research Routes</h2>
      {routeGroups.map((group) => (
        <section class="route-band" aria-labelledby={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-title`}>
          <h3 id={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-title`}>{group.title}</h3>
          <div class="link-grid compact-grid">
            {group.items.map(([href, title, description]) => (
              <article>
                <h4><a href={href}>{title}</a></h4>
                <p>{description}</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </section>

    {sourcePacket && <SourcePacketPanel packet={sourcePacket} mode="hub" />}

    <section class="standards" aria-labelledby="standards-title">
      <h2 id="standards-title">Editorial Standards</h2>
      <ul>
        <li>We reject hate advocacy, racial hierarchy, antisemitism, ableism, and genetic discrimination.</li>
        <li>We do not publish uncontextualized propaganda or primary sources as spectacle.</li>
        <li>Every sensitive page needs sources, content warnings where relevant, and a corrections route.</li>
        <li>We avoid expired-domain SEO abuse, affiliate bait, and low-value content built only for rankings.</li>
      </ul>
    </section>

    <SourceList sources={sources} title="Foundational Sources" />
  </main>
</BaseLayout>
