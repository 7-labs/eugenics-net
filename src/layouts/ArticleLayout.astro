---
import ArticleMeta from "@components/ArticleMeta.astro";
import ContentWarning from "@components/ContentWarning.astro";
import SourcePacketPanel from "@components/SourcePacketPanel.astro";
import SourceList from "@components/SourceList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { articleJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

interface Source {
  label: string;
  url: string;
  note?: string;
}

interface Faq {
  question: string;
  answer: string;
}

interface TocItem {
  id: string;
  label: string;
}

interface BreadcrumbParent {
  label: string;
  href: string;
  path: string;
}

interface SourcePacket {
  title: string;
  contentTier: string;
  audience: string[];
  answerSummary: string;
  reviewStatus: string;
  claimReviewStatus: string;
  lastReviewedBy: string;
  learningObjectives: string[];
  affectedCommunities: string[];
  claimMap: {
    claim: string;
    evidence: string;
    sourceLabels: string[];
  }[];
  deepDiveSections: {
    heading: string;
    body: string;
  }[];
  sourceCoverage: {
    label: string;
    url: string;
    role: string;
    supportedClaims: string[];
    limits: string;
    sensitiveLanguageNotes: string;
    affectedCommunities: string[];
  }[];
  teachingUse: {
    objectives: string[];
    discussionPrompts: string[];
    classroomWarnings: string[];
  };
  doesNotDo: string[];
  relatedTopicPath: {
    label: string;
    href: string;
  }[];
}

interface Props {
  title: string;
  description: string;
  summary: string;
  author: string;
  lastUpdated: Date;
  contentWarning?: string;
  position: string;
  topics?: string[];
  sources: Source[];
  related?: { title: string; href: string }[];
  discussionQuestions?: string[];
  faqs?: Faq[];
  keyTakeaways?: string[];
  misconceptions?: string[];
  reviewStatus?: string;
  sourceNotes?: string;
  tableOfContents?: TocItem[];
  sourcePacket?: SourcePacket;
  contentTier?: "flagship" | "standard";
  audience?: string[];
  claimReviewStatus?: string;
  learningObjectives?: string[];
  lastReviewedBy?: string;
  breadcrumbParent?: BreadcrumbParent;
  path: string;
}

const {
  title,
  description,
  summary,
  author,
  lastUpdated,
  contentWarning,
  position,
  topics = [],
  sources,
  related = [],
  discussionQuestions = [],
  faqs = [],
  keyTakeaways = [],
  misconceptions = [],
  reviewStatus = "Pre-launch editorial review complete; subject-matter review pending.",
  sourceNotes,
  tableOfContents = [],
  sourcePacket,
  contentTier = "standard",
  audience = [],
  claimReviewStatus = "Claims checked against the linked source packet for pre-launch review.",
  learningObjectives = [],
  lastReviewedBy = "Eugenics History & Bioethics Project editorial desk",
  breadcrumbParent = { label: "History", href: "history.html", path: "/history.html" },
  path
} = Astro.props;
const packetSources = (sourcePacket?.sourceCoverage || []).map((source) => ({
  label: source.label,
  url: source.url,
  note: source.role
}));
const sourceMap = new Map<string, Source>();
for (const source of [...sources, ...packetSources]) {
  if (!sourceMap.has(source.url)) sourceMap.set(source.url, source);
}
const mergedSources = Array.from(sourceMap.values());
const jsonLd = [
  articleJsonLd({ title, description, path, author, lastUpdated, sources: mergedSources, topics }),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: breadcrumbParent.label, path: breadcrumbParent.path },
    { name: title, path }
  ]),
  faqJsonLd(faqs)
].filter(Boolean);
const defaultSourceNote = "This page is source-backed by academic, official, or institutional references listed below. It avoids uncontextualized propaganda and does not provide medical, reproductive, genetic, or legal advice.";
const effectiveSourceNote = sourceNotes || defaultSourceNote;
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  jsonLd={jsonLd}
  ogType="article"
  publishedTime={lastUpdated}
  modifiedTime={lastUpdated}
  activePath={breadcrumbParent.path}
>
  <main class="page article-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="index.html">Home</a></li>
        <li><a href={breadcrumbParent.href}>{breadcrumbParent.label}</a></li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Foundational article</p>
      <h1>{title}</h1>
      <p class="lead">{summary}</p>
      <ArticleMeta author={author} lastUpdated={lastUpdated} topics={topics} />
      <p class="review-status"><strong>Review status:</strong> {reviewStatus}</p>
      <p class="review-status"><strong>Content tier:</strong> {contentTier} article. <strong>Claim review:</strong> {claimReviewStatus}</p>
      {audience.length > 0 && <p class="review-status"><strong>Audience:</strong> {audience.join(", ")}</p>}
      <p class="review-status"><strong>Last reviewed by:</strong> {lastReviewedBy}</p>
    </header>

    {contentWarning && <ContentWarning text={contentWarning} />}

    <aside class="notice-panel" aria-labelledby="position-note">
      <h2 id="position-note">Project Position</h2>
      <p>{position}</p>
    </aside>

    <section class="answer-first" aria-labelledby="answer-first-heading">
      <h2 id="answer-first-heading">Answer First</h2>
      <p>{sourcePacket?.answerSummary || summary}</p>
    </section>

    {(keyTakeaways.length > 0 || tableOfContents.length > 0) && (
      <section class="article-orientation" aria-label="Article orientation">
        {keyTakeaways.length > 0 && (
          <div>
            <h2>Key Takeaways</h2>
            <ul>
              {keyTakeaways.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}
        {tableOfContents.length > 0 && (
          <nav class="article-toc" aria-labelledby="toc-heading">
            <h2 id="toc-heading">On This Page</h2>
            <ol>
              {tableOfContents.map((item) => (
                <li><a href={`#${item.id}`}>{item.label}</a></li>
              ))}
            </ol>
          </nav>
        )}
      </section>
    )}

    {learningObjectives.length > 0 && (
      <section class="article-support learning-objectives" aria-labelledby="learning-objectives-heading">
        <h2 id="learning-objectives-heading">Learning Objectives</h2>
        <ul>
          {learningObjectives.map((objective) => <li>{objective}</li>)}
        </ul>
      </section>
    )}

    <article class="article-body">
      <slot />
    </article>

    {sourcePacket && <SourcePacketPanel packet={sourcePacket} mode="article" />}

    {misconceptions.length > 0 && (
      <section class="article-support" aria-labelledby="misconceptions-heading">
        <h2 id="misconceptions-heading">Common Misconceptions</h2>
        <ul>
          {misconceptions.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}

    {faqs.length > 0 && (
      <section class="article-support" aria-labelledby="faq-heading">
        <h2 id="faq-heading">FAQ</h2>
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </section>
    )}

    {discussionQuestions.length > 0 && (
      <section class="article-support" aria-labelledby="discussion-heading">
        <h2 id="discussion-heading">Teaching and Discussion Questions</h2>
        <ol>
          {discussionQuestions.map((question) => <li>{question}</li>)}
        </ol>
      </section>
    )}

    {related.length > 0 && (
      <section class="article-support" aria-labelledby="related-heading">
        <h2 id="related-heading">Related Reading</h2>
        <ul class="related-list">
          {related.map((item) => (
            <li><a href={item.href}>{item.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <section class="article-support source-quality-note" aria-labelledby="source-quality-heading">
      <h2 id="source-quality-heading">Source Quality Note</h2>
      <p>{effectiveSourceNote}</p>
    </section>

    <SourceList sources={mergedSources} />
  </main>
</BaseLayout>
